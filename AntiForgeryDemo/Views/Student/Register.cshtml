@model AntiForgeryDemo.Models.Student
@{
}

<h2>Student Registration</h2>

<form asp-action="Register" method="post">

    @Html.AntiForgeryToken()

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <br />

    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>

    <br />

    <button type="submit">
        Register
    </button>

</form>

<h3>@ViewBag.Message</h3>